# scrapers/hoopR_historical_pull.R
library(hoopR)
library(toRvik)
library(dplyr)
library(arrow)
library(purrr)
# Create output directory if it doesn't exist
dir.create("data/raw", recursive = TRUE, showWarnings = FALSE)
# 1. Team box scores (seasons 2020-2025)
message("Pulling team box scores...")
progressr::with_progress({
team_box <- hoopR::load_mbb_team_box(seasons = 2020:2025)
})
cat(nrow(team_box), "rows from", n_distinct(team_box$game_id), "games\n")
# 2. Player box scores
message("Pulling player box scores...")
progressr::with_progress({
player_box <- hoopR::load_mbb_player_box(seasons = 2020:2025)
})
# 3. Schedule
message("Pulling schedule...")
progressr::with_progress({
schedule <- hoopR::load_mbb_schedule(seasons = 2020:2025)
})
# 4. BartTorvik ratings
message("Pulling BartTorvik ratings...")
bt_all <- purrr::map_dfr(2020:2025, ~toRvik::bart_ratings(year = .x))
# Test each year individually
for (yr in 2020:2025) {
tryCatch({
df <- toRvik::bart_ratings(year = yr)
cat(yr, "- OK:", nrow(df), "rows\n")
}, error = function(e) {
cat(yr, "- FAILED:", e$message, "\n")
})
}
# Pull only working years from toRvik
bt_working <- purrr::map_dfr(2020:2023, ~toRvik::bart_ratings(year = .x))
arrow::write_parquet(bt_working, "data/raw/barttorvik_2020_2023.parquet")
cat("Saved", nrow(bt_working), "rows for 2020-2023\n")
devtools::install_github("andreweatherman/cbbdata")
library(cbbdata)
# Pull 2024 and 2025 via cbbdata
bt_2024 <- cbbdata::cbd_torvik_team_factors(year = 2024)
