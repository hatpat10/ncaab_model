colnames(bt_2024)
library(cbbdata)
library(dplyr)
library(arrow)
bt_2024 <- cbbdata::cbd_torvik_ratings(year = 2024)
bt_2025 <- cbbdata::cbd_torvik_ratings(year = 2025)
bt_recent <- dplyr::bind_rows(bt_2024, bt_2025)
cat("Total rows:", nrow(bt_recent), "\n")
cat("Years:", unique(bt_recent$year), "\n")
arrow::write_parquet(bt_recent, "data/raw/barttorvik_2024_2025.parquet")
cat("Saved to data/raw/barttorvik_2024_2025.parquet\n")
library(hoopR)
library(dplyr)
library(arrow)
library(progressr)
# 1. Team box scores
message("Pulling team box scores (this takes a few minutes)...")
progressr::with_progress({
team_box <- hoopR::load_mbb_team_box(seasons = 2020:2025)
})
cat("Team box:", nrow(team_box), "rows,", n_distinct(team_box$game_id), "games\n")
# 2. Player box scores
message("Pulling player box scores...")
progressr::with_progress({
player_box <- hoopR::load_mbb_player_box(seasons = 2020:2025)
})
cat("Player box:", nrow(player_box), "rows\n")
# 3. Schedule
message("Pulling schedule...")
progressr::with_progress({
schedule <- hoopR::load_mbb_schedule(seasons = 2020:2025)
})
cat("Schedule:", nrow(schedule), "rows\n")
# 4. Save everything
message("Saving to parquet...")
arrow::write_parquet(team_box,   "data/raw/hoopR_team_box_2020_2025.parquet")
arrow::write_parquet(player_box, "data/raw/hoopR_player_box_2020_2025.parquet")
arrow::write_parquet(schedule,   "data/raw/hoopR_schedule_2020_2025.parquet")
message("Done! All files saved to data/raw/")
