library(cbbdata)
library(arrow)
library(dplyr)
bt_2024 <- cbbdata::cbd_torvik_team_factors(year = 2024)
# Check what the function returns before the mutate error
bt_2024 <- tryCatch(
cbbdata::cbd_torvik_team_factors(year = 2024),
error = function(e) e
)
# Try a different cbbdata function instead
bt_2024 <- cbbdata::cbd_torvik_ratings(year = 2024)
